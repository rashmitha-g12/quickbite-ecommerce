# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────
# Local:   mongodb://localhost:27017/ecommerce
# Atlas:   mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/ecommerce
MONGODB_URI=mongodb://localhost:27017/ecommerce

# ─── JWT ──────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────
# Frontend origin (Vercel URL in production)
CLIENT_URL=http://127.0.0.1:5173

# ─── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100


# ─── Email (Nodemailer) ───────────────────────────────────
# Gmail setup:
#   1. Go to myaccount.google.com → Security → 2-Step Verification (enable it)
#   2. Search "App passwords" → Select app: Mail → Generate
#   3. Copy the 16-char password and paste below (no spaces)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_16_char_app_password
